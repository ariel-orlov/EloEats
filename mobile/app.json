{
  "expo": {
    "name": "EloEats",
    "slug": "eloeats",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2d6a4f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.eloeats.app"
    },
    "android": {
      "package": "com.eloeats.app",
      "adaptiveIcon": {
        "backgroundColor": "#2d6a4f"
      }
    },
    "scheme": "eloeats",
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
    ]
  }
}
